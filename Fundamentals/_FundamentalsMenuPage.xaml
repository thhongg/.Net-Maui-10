<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
            x:Class="MyMauiApp.Fundamentals._FundamentalsMenuPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0,30,20"
            Spacing="25">
            <Label x:Name="label"
                Text="Enable dark mode: " />
            <Switch SemanticProperties.Description="{Binding x:DataType='Label', Source={x:Reference label}, Path=Text}" />
            
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label
                Text="MAUI Learning"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" >
                <Label.FontSize>
                    <OnPlatform x:TypeArguments="x:Double" Default="24">
                        <On Platform="WinUI" Value="15"/>
                    </OnPlatform>
                </Label.FontSize>
            </Label>

            <Label
                Text="Welcome to &#10;.NET Multi-platform App UI"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Try to explore the capabilities of MAUI" />

            <Button
                x:Name="CounterBtn"
                Text="Click me" 
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill" />

            <Button
                Text="Navigate Hello Xaml"
                Clicked="HelloXaml" />

            <Button
                Text="Xaml Plus CodePage"
                Clicked="XamlPlusCodePage" />

            <Button
                Text="Grid Demo Page"
                Clicked="GridDemoPage" />

            <Button
                Text="Shared Resources Page"
                Clicked="SharedResourcesPage" />

            <Button
                Text="Static Constants Page"
                Clicked="StaticConstantsPage" />
                
            <Button
                Text="Slider Bindings Page"
                Clicked="SliderBindingsPage"/>

            <Button
                Text="Slider Transforms Page"
                Clicked="SliderTransformsPage"/>

            <Button
                Text="List View Demo Page"
                Clicked="ListViewDemoPage"/>

            <Button
                Text="Clock Page"
                Clicked="ClockPage"/>
            
            <Button
                Text="Hsl Color Scroll Page"
                Clicked="HslColorScrollPage"/>

            <Button
                Text="Keypad Page"
                Clicked="KeypadPage"/>

            <Button
                Text="Behavior Demo Page"
                Clicked="BehaviorDemoPage"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>