<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
            x:Class="MyMauiApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0,30,20"
            Spacing="25">
            <Label x:Name="label"
                Text="Enable dark mode: " />
            <Switch SemanticProperties.Description="{Binding x:DataType='Label', Source={x:Reference label}, Path=Text}" />

            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label
                Text="Based on learn.microsoft.com"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" >
                <Label.FontSize>
                    <OnPlatform x:TypeArguments="x:Double" Default="24">
                        <On Platform="WinUI" Value="15"/>
                    </OnPlatform>
                </Label.FontSize>
            </Label>

            <Label
                Text="Welcome to &#10;.NET Multi-platform App UI"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Try to explore the capabilities of MAUI" />

            <Button
                x:Name="CounterBtn"
                Text="Click me" 
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill" />

            <Button
                Text="XAML Lessons"
                Clicked="OpenXamlMenu"/>

            <Button
                Text="Fundamentals Lessons"
                Clicked="OpenFundamentalsMenu"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>