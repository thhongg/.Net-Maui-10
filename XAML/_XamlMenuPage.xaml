<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
            x:Class="MyMauiApp.XAML._XamlMenuPage">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <Button Text="Hello Xaml"
                    Clicked="HelloXaml"/>

            <Button Text="Xaml Plus Code"
                    Clicked="XamlPlusCodePage"/>

            <Button Text="Grid Demo"
                    Clicked="GridDemoPage"/>

            <Button Text="Shared Resources"
                    Clicked="SharedResourcesPage"/>

            <Button Text="Static Constants"
                    Clicked="StaticConstantsPage"/>

            <Button Text="Slider Bindings"
                    Clicked="SliderBindingsPage"/>

            <Button Text="Slider Transforms"
                    Clicked="SliderTransformsPage"/>

            <Button Text="ListView Demo"
                    Clicked="ListViewDemoPage"/>

            <Button Text="Clock Page"
                    Clicked="ClockPage"/>

            <Button Text="HSL Color Scroll"
                    Clicked="HslColorScrollPage"/>

            <Button Text="Keypad Page"
                    Clicked="KeypadPage"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>